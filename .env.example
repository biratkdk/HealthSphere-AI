# =============================================================================
# HealthSphere AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before starting the stack.
# Lines starting with # are comments and are ignored by the application.
# NEVER commit your real .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=local
# Values: local | staging | production
# In production the app enforces secret strength checks and secure cookies.

APP_NAME=HealthSphere AI Backend
API_PREFIX=/api/v1
LOG_LEVEL=INFO
SERVICE_NAME=healthsphere-api

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# For local development SQLite is fine. For staging/production use PostgreSQL.
DATABASE_URL=sqlite:///./healthsphere.db
# DATABASE_URL=postgresql+psycopg2://healthsphere:CHANGE_ME@localhost:5432/healthsphere

# Unpooled URL used for Alembic migrations (skips pgBouncer / connection pools).
# Leave empty to reuse DATABASE_URL.
DATABASE_URL_UNPOOLED=

# Connection pool settings (PostgreSQL only — ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Database credentials (referenced by docker-compose)
DB_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# Security — CHANGE ALL OF THESE IN PRODUCTION
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-in-real-environments
JWT_ALGORITHM=HS256
SESSION_SECRET_KEY=replace-this-session-secret
SERVICE_API_KEY=change-me-service-key

# Minimum 32 characters. Used to authenticate /internal/* cron endpoints.
CRON_SECRET=replace-this-cron-secret-min-32-chars-long

ENFORCE_AUTH=true
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=14

SECURITY_HEADERS_ENABLED=true

# -----------------------------------------------------------------------------
# CORS / Frontend
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=
FRONTEND_APP_URL=http://localhost:3000

# Frontend environment variables (Vite / CRA)
VITE_API_BASE_URL=http://localhost:8000
REACT_APP_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME
CELERY_BROKER_URL=redis://:CHANGE_ME@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false

# -----------------------------------------------------------------------------
# Background Jobs
# -----------------------------------------------------------------------------
TASK_EXECUTION_MODE=dispatcher
# Values: dispatcher | inline | celery
# Use 'celery' in production with the Celery worker container running.

DISPATCHER_BATCH_SIZE=4
JOB_LEASE_SECONDS=90
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BACKOFF_SECONDS=20

# -----------------------------------------------------------------------------
# Data Retention
# -----------------------------------------------------------------------------
REPORT_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
NOTIFICATION_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Bootstrap Accounts (seeded on first startup — change in production)
# -----------------------------------------------------------------------------
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=AdminPass123!
BOOTSTRAP_CLINICIAN_USERNAME=clinician
BOOTSTRAP_CLINICIAN_PASSWORD=ClinicianPass123!
BOOTSTRAP_ANALYST_USERNAME=analyst
BOOTSTRAP_ANALYST_PASSWORD=AnalystPass123!
SEED_DEMO_DATA=true
AUTO_MIGRATE=false
DEFAULT_PATIENT_ID=1001

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
STORAGE_BACKEND=auto
# Values: auto | local | vercel_blob
# 'auto' uses local storage unless BLOB_READ_WRITE_TOKEN is set.

STORAGE_ROOT=./storage
BLOB_READ_WRITE_TOKEN=
BLOB_ACCESS=private
BLOB_PREFIX=healthsphere
BLOB_ADD_RANDOM_SUFFIX=true

# -----------------------------------------------------------------------------
# Authentication Providers
# -----------------------------------------------------------------------------

# Google OAuth2
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVER_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_PROVIDER_LABEL=Google
GOOGLE_PROVIDER_DESCRIPTION=Use Google to create or access your workspace.

# Facebook OAuth2
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_AUTHORIZE_URL=https://www.facebook.com/dialog/oauth
FACEBOOK_ACCESS_TOKEN_URL=https://graph.facebook.com/oauth/access_token
FACEBOOK_USERINFO_URL=https://graph.facebook.com/me?fields=id,name,email
FACEBOOK_PROVIDER_LABEL=Facebook
FACEBOOK_PROVIDER_DESCRIPTION=Use Facebook to create or access your workspace.

# Generic OIDC (Google Workspace / Okta / Azure AD / etc.)
OIDC_ENABLED=false
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SERVER_METADATA_URL=
OIDC_PROVIDER_LABEL=Google Workspace
OIDC_PROVIDER_DESCRIPTION=Use your organization's identity provider for a managed sign-in experience.
OIDC_PROVIDER_BRAND=google

# Role mapping for federated users
AUTH_DEFAULT_ROLE=clinician
AUTH_ROLE_CLAIM=role
AUTH_ADMIN_EMAILS=
OIDC_DEFAULT_ROLE=clinician
OIDC_ROLE_CLAIM=role
OIDC_ADMIN_EMAILS=

# Set to true to let the SSO provider overwrite roles assigned by admins.
# Default is false: admin-assigned roles are preserved across SSO logins.
OIDC_OVERRIDE_ROLE_ON_LOGIN=false

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=8
ALLOWED_IMAGING_CONTENT_TYPES=image/png,image/jpeg,application/dicom

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LOGIN_ATTEMPTS=8
RATE_LIMIT_SIGNUP_ATTEMPTS=4
RATE_LIMIT_UPLOAD_ATTEMPTS=15
RATE_LIMIT_BACKEND=auto
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_KEY_PREFIX=healthsphere:ratelimit

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
OTLP_ENDPOINT=
# Example: http://otel-collector:4318/v1/traces

# -----------------------------------------------------------------------------
# Realtime / SSE
# -----------------------------------------------------------------------------
STREAM_TOKEN_EXPIRE_MINUTES=30
REALTIME_STREAM_INTERVAL_SECONDS=4
