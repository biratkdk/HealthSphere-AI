{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,frontend/**,docs/**,deployment/**,airflow/**,backend/tests/**,ml_pipeline/data/**,ml_pipeline/notebooks/**,ml_pipeline/training/**,scripts/**,.pytest_cache/**,__pycache__/**}"
    }
  },

  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],

  "env": {
    "ENVIRONMENT":              "vercel",
    "TASK_EXECUTION_MODE":      "dispatcher",
    "STORAGE_BACKEND":          "auto",
    "AUTO_MIGRATE":             "true",
    "SEED_DEMO_DATA":           "true",
    "SECURITY_HEADERS_ENABLED": "true",
    "METRICS_ENABLED":          "false",
    "ALLOWED_ORIGINS":          "https://healthsphere-ai.vercel.app,http://localhost:3000,http://localhost:5173"
  }
}
