{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],

  "env": {
    "ENVIRONMENT":              "vercel",
    "TASK_EXECUTION_MODE":      "dispatcher",
    "STORAGE_BACKEND":          "auto",
    "AUTO_MIGRATE":             "true",
    "SEED_DEMO_DATA":           "true",
    "SECURITY_HEADERS_ENABLED": "true",
    "METRICS_ENABLED":          "false"
  }
}
