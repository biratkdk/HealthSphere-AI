{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",

  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],

  "build": {
    "env": {
      "VITE_API_BASE_URL": "https://healthsphere-ai-backend.vercel.app"
    }
  }
}
